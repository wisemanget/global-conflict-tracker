{
  "name": "global-conflict-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run archive:snapshot",
    "dev": "vite",
    "refresh:stamp": "node scripts/stampLastUpdated.mjs",
    "archive:snapshot": "node scripts/archiveSnapshot.mjs",
    "refresh:data": "npm run refresh:stamp && npm run build",
    "prebuild": "npm run archive:snapshot",
    "build": "vite build",
    "prepreview": "npm run archive:snapshot",
    "preview": "vite preview"
  },
  "dependencies": {
    "plotly.js-geo-dist": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10"
  }
}
